{
  "name": "@mdtero/extension",
  "private": true,
  "type": "module",
  "dependencies": {
    "@mdtero/shared": "file:../shared"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.0",
    "vitest": "^4.1.7"
  },
  "scripts": {
    "build": "MDTERO_EXTENSION_PROFILE=store node esbuild.config.mjs",
    "build:dev": "MDTERO_EXTENSION_PROFILE=dev node esbuild.config.mjs",
    "build:store": "MDTERO_EXTENSION_PROFILE=store node esbuild.config.mjs",
    "package:dev": "npm run build:dev && node scripts/package-dev.mjs",
    "package:webstore": "npm run build:store && node scripts/package-webstore.mjs",
    "store:chrome-draft": "node scripts/store-draft.mjs chrome-draft",
    "store:edge-draft": "node scripts/store-draft.mjs edge-draft",
    "store:draft-all": "node scripts/store-draft.mjs draft-all",
    "test": "vitest run"
  }
}
